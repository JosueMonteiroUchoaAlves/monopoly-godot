[sub_resource type="Shader" id="Shader_7ho8i"]
code = "shader_type canvas_item;
render_mode blend_mix;
uniform int particles_anim_h_frames;
uniform int particles_anim_v_frames;
uniform bool particles_anim_loop;

uniform sampler2D noise_tex : repeat_enable;
uniform vec4 fire_edge_color : source_color = vec4(1.0, 0.15, 0.0, 1.0); 
uniform vec4 fire_core_color : source_color = vec4(1.0, 0.9, 0.0, 1.0); 
uniform float edge_thickness = 0.17;

// 1. Variável de ponte para transitar o UV puro da geometria para os pixels
varying vec2 base_uv;

void vertex() {
    // 2. Salva o UV quadrado (0.0 a 1.0) antes dele ser retalhado em 49 partes
    base_uv = UV; 
    
    float h_frames = float(particles_anim_h_frames);
    float v_frames = float(particles_anim_v_frames);
    VERTEX.xy /= vec2(h_frames, v_frames);
    float particle_total_frames = float(particles_anim_h_frames * particles_anim_v_frames);
    float particle_frame = floor(INSTANCE_CUSTOM.z * float(particle_total_frames));
    if (!particles_anim_loop) {
        particle_frame = clamp(particle_frame, 0.0, particle_total_frames - 1.0);
    } else {
        particle_frame = mod(particle_frame, particle_total_frames);
    }   
    UV /= vec2(h_frames, v_frames);
    UV += vec2(mod(particle_frame, h_frames) / h_frames, floor((particle_frame + 0.5) / h_frames) / v_frames);
}

void fragment() {
    vec4 tex_color = texture(TEXTURE, UV);
    if (tex_color.a == 0.0) discard;

    float life = COLOR.a; 
    
    // 3. Lê o ruído usando o UV puro. A distorção horizontal acaba aqui.
    float noise = texture(noise_tex, base_uv).r;
    
    float threshold = life * (1.0 + edge_thickness * 2.0) - edge_thickness;

    if (noise > threshold) {
        discard;
    }

    float edge_dist = threshold - noise;
    if (edge_dist < edge_thickness) {
        float fire_blend = edge_dist / edge_thickness;
        tex_color.rgb = mix(fire_edge_color.rgb, fire_core_color.rgb, fire_blend);
        tex_color.a = 1.0; 
    }

    COLOR = tex_color;
}"

